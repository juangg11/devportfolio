---
import { siteConfig } from "../config";
---

<section id="about" class="p-8 sm:p-12 md:p-16 lg:p-24" style={`--accent-color: ${siteConfig.accentColor}`}>
  <div class="reveal-section">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900 tracking-tight leading-none">
          About<br/>Me
        </h2>
        <div class="w-8 h-1 mt-4 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>
      </div>

      <div class="lg:col-span-8 space-y-8">
        <p class="text-lg sm:text-xl md:text-2xl leading-relaxed text-gray-500 font-light">
          {siteConfig.aboutMe}
        </p>

        <div class="pt-2">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">Technologies & Skills</p>
          <div class="flex flex-wrap gap-2">
            {
              siteConfig.skills.map((skill) => (
                <span class="skill-chip px-3 sm:px-4 py-1.5 sm:py-2 text-sm sm:text-base font-medium cursor-default">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes revealUp {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reveal-section {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-section.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .skill-chip {
    background: #f4f4f5;
    color: #374151;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .skill-chip:hover {
    background: white;
    border-color: var(--accent-color);
    color: var(--accent-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px -2px rgba(0,0,0,0.08);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("visible")),
    { threshold: 0.12 }
  );
  document.querySelectorAll(".reveal-section").forEach((el) => observer.observe(el));
</script>