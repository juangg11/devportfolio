---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<section id="about" class="section-base" aria-labelledby="about-heading">
  <div class="section-inner reveal-up">

    <!-- Section header -->
    <div class="section-label">
      <span class="label-line"></span>
      <span class="label-text">{t(lang, 'about.title')}</span>
    </div>

    <div class="about-grid">

      <!-- Large title column -->
      <div class="about-heading-col">
        <h2 id="about-heading" class="section-display-title">
          {t(lang, 'about.title')}
        </h2>
      </div>

      <!-- Content column -->
      <div class="about-content-col">
        <p class="about-body">
          {siteConfig.aboutMe}
        </p>

        <div class="skills-block">
          <p class="skills-label">{t(lang, 'about.skills')}</p>
          <div class="skills-grid">
            {siteConfig.skills.map((skill: string) => (
              <span class="skill-tag">{skill}</span>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .section-base {
    padding: 6rem 1.5rem;
    background: #0a0a0c;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  @media (min-width: 640px)  { .section-base { padding: 7rem 2.5rem; } }
  @media (min-width: 1024px) { .section-base { padding: 9rem 4rem; } }

  .section-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* Section label row */
  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }
  .label-line {
    flex: 0 0 40px;
    height: 1px;
    background: linear-gradient(90deg, #fbbf24, rgba(251,191,36,0.2));
  }
  .label-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fbbf24;
  }

  /* Display title */
  .section-display-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700;
    color: #fafafa;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  /* About grid */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .about-grid { grid-template-columns: 5fr 7fr; gap: 5rem; align-items: start; }
  }

  .about-body {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #a1a1aa;
    font-weight: 300;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 768px) { .about-body { font-size: 1.25rem; } }

  /* Skills */
  .skills-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #52525b;
    margin-bottom: 1rem;
  }
  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .skill-tag {
    padding: 0.4rem 0.9rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #a1a1aa;
    cursor: default;
    transition: all 0.25s ease;
  }
  .skill-tag:hover {
    border-color: rgba(251,191,36,0.4);
    color: #fbbf24;
    background: rgba(251,191,36,0.06);
    transform: translateY(-1px);
  }

  /* Scroll reveal */
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(.16,1,.3,1), transform 0.8s cubic-bezier(.16,1,.3,1);
  }
  .reveal-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal-up').forEach(el => io.observe(el));
</script>
