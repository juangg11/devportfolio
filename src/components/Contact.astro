---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<section id="contact" class="section-base" aria-labelledby="contact-heading">
  <div class="section-inner reveal-up">

    <div class="section-label">
      <span class="label-line"></span>
      <span class="label-text">{t(lang, 'nav.contact')}</span>
    </div>

    <div class="contact-content">
      <h2 id="contact-heading" class="contact-title">
        {t(lang, 'contact.title')}
      </h2>
      <p class="contact-sub">{t(lang, 'contact.subtitle')}</p>

      <div class="contact-links">
        {siteConfig.social?.email && (
          <a href={`mailto:${siteConfig.social.email}`} class="contact-btn contact-btn-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
            {t(lang, 'contact.email')}
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="contact-btn contact-btn-secondary">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 1 0-4 0"/>
              <rect x="3" y="3" width="18" height="18" rx="4"/>
            </svg>
            {t(lang, 'contact.linkedin')}
          </a>
        )}
      </div>
    </div>

    <!-- Decorative -->
    <div class="contact-deco" aria-hidden="true">
      <span class="deco-char">&lt;</span>
      <span class="deco-word">hello</span>
      <span class="deco-char">/&gt;</span>
    </div>

  </div>
</section>

<style>
  .section-base {
    padding: 7rem 1.5rem;
    background: #0a0a0c;
    border-top: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 640px)  { .section-base { padding: 8rem 2.5rem; } }
  @media (min-width: 1024px) { .section-base { padding: 10rem 4rem; } }

  .section-inner { max-width: 72rem; margin: 0 auto; position: relative; }

  .section-label {
    display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;
  }
  .label-line { flex: 0 0 40px; height: 1px; background: linear-gradient(90deg, #fbbf24, rgba(251,191,36,0.2)); }
  .label-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: #fbbf24;
  }

  .contact-content { max-width: 48rem; }

  .contact-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 700; color: #fafafa;
    line-height: 0.95; letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .contact-sub {
    font-size: 1.125rem; color: #71717a;
    font-weight: 300; line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .contact-links { display: flex; flex-wrap: wrap; gap: 1rem; }

  .contact-btn {
    display: inline-flex; align-items: center; gap: 0.75rem;
    padding: 0.875rem 1.75rem; border-radius: 9999px;
    font-size: 0.9375rem; font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .contact-btn-primary {
    background: #fbbf24; color: #0a0a0c;
    box-shadow: 0 0 32px -8px rgba(251,191,36,0.5);
  }
  .contact-btn-primary:hover {
    background: #fde68a;
    box-shadow: 0 0 48px -4px rgba(251,191,36,0.6);
    transform: translateY(-2px);
  }
  .contact-btn-secondary {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    color: #a1a1aa;
  }
  .contact-btn-secondary:hover {
    border-color: rgba(251,191,36,0.4); color: #fbbf24;
    background: rgba(251,191,36,0.06);
    transform: translateY(-2px);
  }

  /* Decorative background text */
  .contact-deco {
    position: absolute;
    bottom: -2rem; right: -1rem;
    font-family: 'Playfair Display', serif;
    font-size: clamp(5rem, 14vw, 12rem);
    font-weight: 700; letter-spacing: -0.04em;
    color: rgba(251,191,36,0.03);
    pointer-events: none; user-select: none;
    white-space: nowrap;
    line-height: 1;
  }
  .deco-char { color: rgba(251,191,36,0.05); }
  .deco-word { color: rgba(255,255,255,0.02); }

  .reveal-up {
    opacity: 0; transform: translateY(40px);
    transition: opacity 0.9s cubic-bezier(.16,1,.3,1), transform 0.9s cubic-bezier(.16,1,.3,1);
  }
  .reveal-up.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('#contact .reveal-up').forEach(el => io.observe(el));
</script>
