---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-[#fafafa] py-24 md:h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Subtle noise texture overlay -->
  <div class="absolute inset-0 -z-10 hero-noise"></div>

  <!-- Gradient blob -->
  <div
    class="absolute inset-0 -z-10 hero-gradient"
    style={`background: radial-gradient(ellipse 900px 700px at -5% -10%, ${siteConfig.accentColor}30 0%, ${siteConfig.accentColor}12 35%, transparent 70%)`}
  ></div>

  <!-- Animated grid -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full"
  >
    <defs>
      <pattern
        id="hero-grid"
        x="0"
        y="0"
        width="60"
        height="60"
        patternUnits="userSpaceOnUse"
      >
        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(0,0,0,0.04)" stroke-width="1"/>
      </pattern>
    </defs>
    <rect fill="url(#hero-grid)" width="100%" height="100%" />
  </svg>

  <!-- Floating code symbols -->
  <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
    {['</>','{}','()','[]','=>','::'].map((sym, i) => (
      <span
        class="floating-sym absolute font-mono text-sm select-none"
        style={`color: ${siteConfig.accentColor}; opacity: 0.12; top: ${15 + i * 13}%; left: ${60 + (i % 3) * 12}%; animation-delay: ${i * 0.8}s;`}
      >{sym}</span>
    ))}
  </div>

  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div>
      <div class="hero-tag inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gray-200 bg-white/60 backdrop-blur-sm mb-8 text-sm text-gray-500 font-medium">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style={`background-color: ${siteConfig.accentColor}`}></span>
        Available for work
      </div>

      <h2 class="hero-sub text-xl sm:text-2xl md:text-3xl font-light tracking-wide text-gray-400">
        Hello there 👋
      </h2>
      <h1 class="hero-title mt-3 sm:mt-4 text-pretty text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-gray-900 leading-[0.95]">
        I'm <span class="accent-text" style={`color: ${siteConfig.accentColor}`}>{siteConfig.name}</span>
      </h1>
      <p class="hero-desc mt-5 sm:mt-7 text-pretty text-lg sm:text-xl md:text-2xl font-light text-gray-500 max-w-xl leading-relaxed">
        {siteConfig.title}
      </p>

      <div class="hero-cta mt-8 sm:mt-10 flex items-center gap-4">
        <a
          href="#about"
          class="cta-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-white text-sm font-semibold transition-all duration-300"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          View my work
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div
    class="hero-socials absolute bottom-0 left-0 right-0 p-8 sm:p-12 md:p-24 flex gap-x-5 text-gray-400"
  >
    {
      siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="social-icon transition-all duration-300 hover:text-[var(--accent-color)] hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 sm:h-6 sm:w-6">
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.linkedin && (
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon transition-all duration-300 hover:text-[var(--accent-color)] hover:-translate-y-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 sm:h-6 sm:w-6">
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" />
            <path d="M16 16v-3a2 2 0 1 0 -4 0" />
            <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.twitter && (
        <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="social-icon transition-all duration-300 hover:text-[var(--accent-color)] hover:-translate-y-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 sm:h-6 sm:w-6">
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
            <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-icon transition-all duration-300 hover:text-[var(--accent-color)] hover:-translate-y-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 sm:h-6 sm:w-6">
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
          </svg>
        </a>
      )
    }
  </div>
</div>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes floatSym {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50%       { transform: translateY(-12px) rotate(3deg); }
  }

  .hero-tag   { animation: fadeUp 0.6s ease-out 0.1s both; }
  .hero-sub   { animation: fadeUp 0.6s ease-out 0.25s both; }
  .hero-title { animation: fadeUp 0.7s ease-out 0.4s both; }
  .hero-desc  { animation: fadeUp 0.6s ease-out 0.55s both; }
  .hero-cta   { animation: fadeUp 0.6s ease-out 0.7s both; }
  .hero-socials { animation: fadeIn 0.8s ease-out 0.9s both; }

  .floating-sym {
    animation: floatSym 6s ease-in-out infinite;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px var(--accent-color, #3b82f6)44;
  }

  .hero-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
    opacity: 0.5;
  }
</style>