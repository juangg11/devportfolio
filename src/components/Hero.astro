---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<section
  id="hero"
  class="hero-section relative min-h-screen flex flex-col justify-center overflow-hidden"
  aria-label="Hero"
>
  <!-- Animated mesh background -->
  <div class="hero-bg absolute inset-0 -z-10"></div>

  <!-- Scanline overlay texture -->
  <div class="scanlines absolute inset-0 -z-10 pointer-events-none"></div>

  <!-- Orbiting accent ring -->
  <div class="orbit-ring absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 pointer-events-none"></div>

  <!-- Corner decorations -->
  <div class="corner-tl absolute top-8 left-8 w-10 h-10 border-t-2 border-l-2 border-amber-400/40"></div>
  <div class="corner-br absolute bottom-8 right-8 w-10 h-10 border-b-2 border-r-2 border-amber-400/40"></div>

  <!-- Main content -->
  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 sm:px-10 md:px-16 pt-28 pb-20">

    <!-- Status badge -->
    <div class="hero-tag inline-flex items-center gap-2.5 px-4 py-2 rounded-full mb-10 border border-amber-400/25 bg-amber-400/8 backdrop-blur-sm">
      <span class="w-2 h-2 rounded-full bg-amber-400 pulse-dot"></span>
      <span class="text-amber-300 text-sm font-medium tracking-wide">{t(lang, 'hero.available')}</span>
    </div>

    <!-- Greeting -->
    <p class="hero-greeting text-zinc-400 text-lg sm:text-xl font-light tracking-widest uppercase mb-4 font-mono">
      {t(lang, 'hero.greeting')}
    </p>

    <!-- Name — split letter animation -->
    <h1 class="hero-name font-display leading-[0.88] tracking-tighter mb-6" aria-label={`I'm ${siteConfig.name}`}>
      <span class="text-block block text-zinc-100">I'm</span>
      <span class="name-accent text-block block">{siteConfig.name}</span>
    </h1>

    <!-- Title typewriter -->
    <p class="hero-title text-zinc-300 text-xl sm:text-2xl md:text-3xl font-light max-w-2xl leading-relaxed mb-10">
      {siteConfig.title}
    </p>

    <!-- CTAs -->
    <div class="hero-cta flex flex-wrap items-center gap-4">
      <a
        href="#projects"
        class="cta-primary inline-flex items-center gap-3 px-7 py-3.5 rounded-full font-semibold text-zinc-950 bg-amber-400 hover:bg-amber-300 transition-all duration-300 text-sm tracking-wide"
      >
        {t(lang, 'hero.cta')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <!-- Social icons -->
      <div class="flex items-center gap-3 ml-2">
        {siteConfig.social?.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-btn">
            <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-btn">
            <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 1 0-4 0"/>
              <rect x="3" y="3" width="18" height="18" rx="4"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.email && (
          <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="social-btn">
            <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 scroll-hint">
    <span class="text-zinc-600 text-xs tracking-widest uppercase font-mono">{t(lang, 'hero.scroll')}</span>
    <div class="scroll-line w-px h-12 bg-gradient-to-b from-amber-400/60 to-transparent"></div>
  </div>
</section>

<style>
  /* Typography */
  .hero-name {
    font-size: clamp(3.5rem, 12vw, 10rem);
    font-family: 'Playfair Display', Georgia, serif;
  }
  .text-block { display: block; }
  .name-accent {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 40%, #fde68a 70%, #f59e0b 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Background mesh */
  .hero-bg {
    background-color: #0a0a0c;
    background-image:
      radial-gradient(ellipse 80% 60% at 70% 30%, rgba(251,191,36,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(251,191,36,0.04) 0%, transparent 55%);
  }

  /* Scanlines */
  .scanlines {
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255,255,255,0.012) 2px,
      rgba(255,255,255,0.012) 4px
    );
  }

  /* Orbiting ring */
  .orbit-ring {
    width: 600px;
    height: 600px;
    border-radius: 50%;
    border: 1px solid rgba(251,191,36,0.06);
    animation: orbitSpin 30s linear infinite;
  }
  .orbit-ring::before {
    content: '';
    position: absolute;
    top: -4px;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fbbf24;
    transform: translateX(-50%);
    box-shadow: 0 0 12px 4px rgba(251,191,36,0.4);
  }
  @keyframes orbitSpin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Pulse dot */
  .pulse-dot {
    box-shadow: 0 0 0 0 rgba(251,191,36,0.4);
    animation: pulsate 2s ease-out infinite;
  }
  @keyframes pulsate {
    0%   { box-shadow: 0 0 0 0 rgba(251,191,36,0.5); }
    70%  { box-shadow: 0 0 0 8px rgba(251,191,36,0); }
    100% { box-shadow: 0 0 0 0 rgba(251,191,36,0); }
  }

  /* Social buttons */
  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    color: #a1a1aa;
    transition: all 0.25s ease;
  }
  .social-btn:hover {
    border-color: rgba(251,191,36,0.5);
    color: #fbbf24;
    background: rgba(251,191,36,0.08);
    transform: translateY(-2px);
  }

  /* CTA */
  .cta-primary {
    box-shadow: 0 0 32px -8px rgba(251,191,36,0.4);
  }
  .cta-primary:hover {
    box-shadow: 0 0 44px -4px rgba(251,191,36,0.55);
    transform: translateY(-2px);
  }

  /* Scroll hint */
  .scroll-hint { animation: fadeIn 1s ease 1.5s both; }
  @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }

  /* Entrance animations */
  .hero-tag     { animation: slideUp 0.7s cubic-bezier(.16,1,.3,1) 0.1s both; }
  .hero-greeting{ animation: slideUp 0.7s cubic-bezier(.16,1,.3,1) 0.2s both; }
  .hero-name    { animation: slideUp 0.9s cubic-bezier(.16,1,.3,1) 0.35s both; }
  .hero-title   { animation: slideUp 0.7s cubic-bezier(.16,1,.3,1) 0.55s both; }
  .hero-cta     { animation: slideUp 0.7s cubic-bezier(.16,1,.3,1) 0.7s both; }

  @keyframes slideUp {
    from { opacity:0; transform: translateY(40px); }
    to   { opacity:1; transform: translateY(0); }
  }

  /* Corner decors */
  .corner-tl, .corner-br {
    animation: fadeIn 1.2s ease 0.8s both;
  }
</style>
