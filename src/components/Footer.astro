---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;

const hasProjects   = siteConfig.projects?.length   > 0;
const hasExperience = siteConfig.experience?.length > 0;
const hasEducation  = siteConfig.education?.length  > 0;
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">

    <div class="footer-top">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="#hero" class="footer-logo" aria-label="Back to top">
          <span class="logo-bracket">[</span>
          <span class="logo-name">{siteConfig.name}</span>
          <span class="logo-bracket">]</span>
        </a>
        <p class="footer-tagline">{siteConfig.title}</p>

        <!-- Socials -->
        <div class="footer-socials">
          {siteConfig.social?.github && (
            <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-btn">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.linkedin && (
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-btn">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 1 0-4 0"/>
                <rect x="3" y="3" width="18" height="18" rx="4"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter/X" class="social-btn">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4l11.733 16H20L8.267 4z"/>
                <path d="M4 20l6.768-6.768m2.46-2.46L20 4"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.email && (
            <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="social-btn">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="M3 7l9 6 9-6"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Nav links -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <p class="footer-nav-label">Navigation</p>
        <ul>
          <li><a href="#about"      class="footer-link">{t(lang, 'nav.about')}</a></li>
          {hasProjects   && <li><a href="#projects"   class="footer-link">{t(lang, 'nav.projects')}</a></li>}
          {hasExperience && <li><a href="#experience" class="footer-link">{t(lang, 'nav.experience')}</a></li>}
          {hasEducation  && <li><a href="#education"  class="footer-link">{t(lang, 'nav.education')}</a></li>}
          <li><a href="#contact"    class="footer-link">{t(lang, 'nav.contact')}</a></li>
        </ul>
      </nav>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">
        © {year} {siteConfig.name}. {t(lang, 'footer.rights')}
      </p>
      <p class="footer-made">
        Built with <span class="accent">Astro</span>
      </p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: #080809;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer-inner {
    max-width: 72rem; margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }
  @media (min-width: 640px) { .footer-inner { padding: 5rem 2.5rem 2.5rem; } }

  .footer-top {
    display: grid; grid-template-columns: 1fr;
    gap: 3rem; margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  @media (min-width: 768px) { .footer-top { grid-template-columns: 1fr 1fr; gap: 4rem; } }

  .footer-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.125rem; font-weight: 700;
    text-decoration: none; color: #e4e4e7;
    display: inline-block; margin-bottom: 0.75rem;
    transition: color 0.2s;
  }
  .logo-bracket { color: #fbbf24; }
  .logo-name { transition: color 0.2s; }
  .footer-logo:hover .logo-name { color: #fbbf24; }

  .footer-tagline {
    font-size: 0.875rem; color: #52525b;
    font-weight: 300; line-height: 1.6;
    max-width: 28rem; margin-bottom: 1.5rem;
  }

  .footer-socials { display: flex; gap: 0.625rem; }
  .social-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    color: #52525b; text-decoration: none;
    transition: all 0.25s ease;
  }
  .social-btn:hover {
    border-color: rgba(251,191,36,0.4); color: #fbbf24;
    background: rgba(251,191,36,0.07); transform: translateY(-2px);
  }

  .footer-nav-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: #3f3f46; margin-bottom: 1rem;
  }
  .footer-nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-link {
    font-size: 0.875rem; color: #52525b;
    text-decoration: none; font-weight: 400;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: #fbbf24; }

  .footer-bottom {
    display: flex; flex-wrap: wrap; gap: 1rem;
    justify-content: space-between; align-items: center;
  }
  .footer-copy, .footer-made {
    font-size: 0.75rem; color: #3f3f46; font-weight: 300;
  }
  .accent { color: rgba(251,191,36,0.5); }
</style>
