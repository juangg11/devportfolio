---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
const hasEducation = siteConfig.education?.length > 0;
---

{hasEducation && (
<section id="education" class="section-base" aria-labelledby="education-heading">
  <div class="section-inner">

    <div class="section-label reveal-up">
      <span class="label-line"></span>
      <span class="label-text">{t(lang, 'education.title')}</span>
    </div>

    <div class="edu-layout">
      <div class="edu-title-col reveal-up">
        <h2 id="education-heading" class="section-display-title">
          {t(lang, 'education.title')}
        </h2>
      </div>

      <div class="edu-cards-col">
        {siteConfig.education.map((edu: any, index: number) => (
          <div class="edu-card reveal-up" style={`--delay: ${index * 0.1}s`}>
            <div class="edu-header">
              <div>
                <h3 class="edu-degree">{edu.degree}</h3>
                <p class="edu-school">{edu.school}</p>
              </div>
              <span class="edu-date">{edu.dateRange}</span>
            </div>

            {edu.achievements?.length > 0 && (
              <ul class="edu-achievements">
                {edu.achievements.map((a: string) => (
                  <li class="edu-achievement">
                    <span class="ach-dot" aria-hidden="true">▸</span>
                    <span>{a}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
)}

<style>
  .section-base {
    padding: 6rem 1.5rem;
    background: #0c0c0e;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  @media (min-width: 640px)  { .section-base { padding: 7rem 2.5rem; } }
  @media (min-width: 1024px) { .section-base { padding: 9rem 4rem; } }

  .section-inner { max-width: 72rem; margin: 0 auto; }

  .section-label {
    display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;
  }
  .label-line { flex: 0 0 40px; height: 1px; background: linear-gradient(90deg, #fbbf24, rgba(251,191,36,0.2)); }
  .label-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: #fbbf24;
  }

  .edu-layout {
    display: grid; grid-template-columns: 1fr; gap: 3rem;
  }
  @media (min-width: 1024px) {
    .edu-layout { grid-template-columns: 1fr 2fr; gap: 5rem; align-items: start; }
    .edu-title-col { position: sticky; top: 6rem; }
  }

  .section-display-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700; color: #fafafa;
    line-height: 0.95; letter-spacing: -0.02em;
  }

  .edu-cards-col { display: flex; flex-direction: column; gap: 1.25rem; }

  .edu-card {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.75rem;
    padding: 1.5rem 1.75rem;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .edu-card:hover {
    border-color: rgba(251,191,36,0.2);
    background: rgba(251,191,36,0.03);
  }

  .edu-header {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    justify-content: space-between; align-items: flex-start;
    margin-bottom: 1rem;
  }
  .edu-degree { font-size: 1rem; font-weight: 600; color: #e4e4e7; line-height: 1.3; }
  .edu-school { font-size: 0.875rem; font-weight: 500; color: #fbbf24; margin-top: 0.2rem; opacity: 0.85; }
  .edu-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; font-weight: 500; color: #52525b;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 0.3rem 0.7rem; border-radius: 0.3rem;
    white-space: nowrap; flex-shrink: 0;
  }

  .edu-achievements { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .edu-achievement {
    display: flex; gap: 0.75rem;
    font-size: 0.875rem; line-height: 1.65; color: #71717a; font-weight: 300;
  }
  .ach-dot { color: rgba(251,191,36,0.45); flex-shrink: 0; font-size: 0.7rem; margin-top: 0.3em; }

  .reveal-up {
    opacity: 0; transform: translateY(36px);
    transition: opacity 0.8s cubic-bezier(.16,1,.3,1) var(--delay, 0s),
                transform 0.8s cubic-bezier(.16,1,.3,1) var(--delay, 0s);
  }
  .reveal-up.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.07 }
  );
  document.querySelectorAll('#education .reveal-up').forEach(el => io.observe(el));
</script>
