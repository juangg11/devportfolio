---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
const hasExperience = siteConfig.experience?.length > 0;
---

{hasExperience && (
<section id="experience" class="section-base" aria-labelledby="experience-heading">
  <div class="section-inner">

    <div class="section-label reveal-up">
      <span class="label-line"></span>
      <span class="label-text">{t(lang, 'experience.title')}</span>
    </div>

    <div class="exp-layout">

      <!-- Sticky title -->
      <div class="exp-title-col reveal-up">
        <h2 id="experience-heading" class="section-display-title">
          {t(lang, 'experience.title')}
        </h2>
      </div>

      <!-- Timeline -->
      <div class="exp-timeline-col">
        <div class="timeline">
          {siteConfig.experience.map((exp: any, index: number) => (
            <div class="timeline-item reveal-up" style={`--delay: ${index * 0.12}s`}>
              <!-- Dot -->
              <div class="timeline-dot" aria-hidden="true">
                <span class="dot-inner"></span>
              </div>

              <!-- Card -->
              <div class="exp-card">
                <div class="exp-card-header">
                  <div class="exp-titles">
                    <h3 class="exp-role">{exp.title}</h3>
                    <p class="exp-company">{exp.company}</p>
                  </div>
                  <span class="exp-date">{exp.dateRange}</span>
                </div>

                <ul class="exp-bullets">
                  {exp.bullets.map((bullet: string) => (
                    <li class="exp-bullet">
                      <span class="bullet-dot" aria-hidden="true">▸</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
)}

<style>
  .section-base {
    padding: 6rem 1.5rem;
    background: #0a0a0c;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  @media (min-width: 640px)  { .section-base { padding: 7rem 2.5rem; } }
  @media (min-width: 1024px) { .section-base { padding: 9rem 4rem; } }

  .section-inner { max-width: 72rem; margin: 0 auto; }

  .section-label {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 3rem;
  }
  .label-line { flex: 0 0 40px; height: 1px; background: linear-gradient(90deg, #fbbf24, rgba(251,191,36,0.2)); }
  .label-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: #fbbf24;
  }

  .exp-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .exp-layout { grid-template-columns: 1fr 2fr; gap: 5rem; align-items: start; }
  }

  .section-display-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 700; color: #fafafa;
    line-height: 0.95; letter-spacing: -0.02em;
  }
  @media (min-width: 1024px) {
    .exp-title-col { position: sticky; top: 6rem; }
  }

  /* Timeline */
  .timeline { position: relative; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 0; top: 8px; bottom: 8px;
    width: 1px;
    background: linear-gradient(180deg, rgba(251,191,36,0.4), rgba(251,191,36,0.1) 60%, transparent);
  }

  .timeline-item {
    position: relative;
    padding-left: 2.5rem;
    padding-bottom: 3rem;
  }
  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: 0; top: 6px;
    transform: translateX(-50%);
    width: 13px; height: 13px;
    border-radius: 50%;
    background: #0a0a0c;
    border: 2px solid rgba(251,191,36,0.5);
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.25s;
  }
  .dot-inner {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #fbbf24;
    opacity: 0.7;
  }
  .timeline-item:hover .timeline-dot { border-color: #fbbf24; }
  .timeline-item:hover .dot-inner { opacity: 1; }

  /* Card */
  .exp-card {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .timeline-item:hover .exp-card {
    border-color: rgba(251,191,36,0.2);
    background: rgba(251,191,36,0.03);
  }

  .exp-card-header {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    justify-content: space-between; align-items: flex-start;
    margin-bottom: 1.25rem;
  }
  .exp-role {
    font-size: 1.0625rem; font-weight: 600; color: #e4e4e7;
    line-height: 1.3;
  }
  .exp-company {
    font-size: 0.875rem; font-weight: 500; color: #fbbf24;
    margin-top: 0.2rem; opacity: 0.85;
  }
  .exp-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; font-weight: 500; color: #52525b;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 0.3rem 0.7rem; border-radius: 0.3rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .exp-bullets { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .exp-bullet {
    display: flex; gap: 0.75rem;
    font-size: 0.875rem; line-height: 1.65; color: #71717a; font-weight: 300;
  }
  .bullet-dot { color: rgba(251,191,36,0.5); flex-shrink: 0; font-size: 0.7rem; margin-top: 0.3em; }

  /* Reveal */
  .reveal-up {
    opacity: 0; transform: translateY(36px);
    transition: opacity 0.8s cubic-bezier(.16,1,.3,1) var(--delay, 0s),
                transform 0.8s cubic-bezier(.16,1,.3,1) var(--delay, 0s);
  }
  .reveal-up.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.07 }
  );
  document.querySelectorAll('#experience .reveal-up').forEach(el => io.observe(el));
</script>
