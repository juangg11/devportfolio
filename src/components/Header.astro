---
import { siteConfig } from '../config';
import type { Lang } from '../i18n';
import { t } from '../i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;

const hasProjects   = siteConfig.projects?.length   > 0;
const hasExperience = siteConfig.experience?.length > 0;
const hasEducation  = siteConfig.education?.length  > 0;
---

<header id="site-header" role="banner">
  <nav class="nav-inner" aria-label="Main navigation">

    <!-- Logo / Name -->
    <a href="#hero" class="nav-logo" aria-label="Go to top">
      <span class="logo-bracket text-amber-400">[</span>
      <span class="logo-initials">{siteConfig.name.split(' ').map((n: string) => n[0]).join('')}</span>
      <span class="logo-bracket text-amber-400">]</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li><a href="#about"      class="nav-link">{t(lang, 'nav.about')}</a></li>
      {hasProjects   && <li><a href="#projects"   class="nav-link">{t(lang, 'nav.projects')}</a></li>}
      {hasExperience && <li><a href="#experience" class="nav-link">{t(lang, 'nav.experience')}</a></li>}
      {hasEducation  && <li><a href="#education"  class="nav-link">{t(lang, 'nav.education')}</a></li>}
      <li><a href="#contact"    class="nav-link">{t(lang, 'nav.contact')}</a></li>
    </ul>

    <!-- Right side: lang toggle + mobile menu -->
    <div class="nav-right">
      <!-- Language toggle -->
      <button
        id="lang-toggle"
        class="lang-btn"
        aria-label="Toggle language"
        data-current-lang={lang}
      >
        <span class:list={["lang-opt", { active: lang === 'en' }]}>EN</span>
        <span class="lang-divider">/</span>
        <span class:list={["lang-opt", { active: lang === 'es' }]}>ES</span>
      </button>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="hamburger md:hidden" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-drawer" aria-hidden="true">
    <ul class="mobile-links" role="list">
      <li><a href="#about"      class="mobile-link">{t(lang, 'nav.about')}</a></li>
      {hasProjects   && <li><a href="#projects"   class="mobile-link">{t(lang, 'nav.projects')}</a></li>}
      {hasExperience && <li><a href="#experience" class="mobile-link">{t(lang, 'nav.experience')}</a></li>}
      {hasEducation  && <li><a href="#education"  class="mobile-link">{t(lang, 'nav.education')}</a></li>}
      <li><a href="#contact"    class="mobile-link">{t(lang, 'nav.contact')}</a></li>
    </ul>
  </div>
</header>

<style>
  #site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }
  #site-header.scrolled {
    background: rgba(10,10,12,0.88);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border-bottom: 1px solid rgba(251,191,36,0.12);
    box-shadow: 0 4px 32px rgba(0,0,0,0.4);
  }

  .nav-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .nav-logo {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    color: #e4e4e7;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .nav-logo:hover .logo-initials { color: #fbbf24; }
  .logo-initials { transition: color 0.2s; }

  /* Desktop nav links */
  .nav-links {
    display: none;
    list-style: none;
    padding: 0; margin: 0;
    gap: 0.25rem;
  }
  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #a1a1aa;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s ease, background 0.2s ease;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 1.5px;
    background: #fbbf24;
    border-radius: 9999px;
    transform: translateX(-50%);
    transition: width 0.25s ease;
  }
  .nav-link:hover,
  .nav-link.active {
    color: #fafafa;
  }
  .nav-link:hover::after,
  .nav-link.active::after { width: 55%; }

  /* Right side */
  .nav-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }

  /* Language toggle */
  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .lang-btn:hover {
    border-color: rgba(251,191,36,0.4);
    background: rgba(251,191,36,0.07);
  }
  .lang-opt {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #71717a;
    transition: color 0.2s;
  }
  .lang-opt.active { color: #fbbf24; }
  .lang-divider { color: #3f3f46; font-size: 0.7rem; }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #a1a1aa;
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); background: #fbbf24; }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); background: #fbbf24; }

  /* Mobile drawer */
  .mobile-drawer {
    display: none;
    flex-direction: column;
    background: rgba(10,10,12,0.97);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(251,191,36,0.1);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }
  .mobile-drawer.open {
    max-height: 400px;
  }
  @media (max-width: 767px) {
    .mobile-drawer { display: flex; }
  }

  .mobile-links {
    list-style: none;
    padding: 1.5rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .mobile-link {
    display: block;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: #a1a1aa;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  .mobile-link:hover {
    color: #fbbf24;
    background: rgba(251,191,36,0.06);
    border-color: rgba(251,191,36,0.15);
  }
</style>

<script>
  // Scroll behavior
  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // Active nav link
  const sections = document.querySelectorAll('section[id], div[id="hero"], section[id="hero"]');
  const navLinks  = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href')?.slice(1) === e.target.id));
      }
    }),
    { threshold: 0.35 }
  );
  sections.forEach(s => io.observe(s));

  // Mobile menu
  const btn   = document.getElementById('mobile-menu-btn')!;
  const drawer = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => {
    const open = drawer.classList.toggle('open');
    btn.classList.toggle('open', open);
    btn.setAttribute('aria-expanded', String(open));
    drawer.setAttribute('aria-hidden', String(!open));
  });
  drawer.querySelectorAll('.mobile-link').forEach(l =>
    l.addEventListener('click', () => {
      drawer.classList.remove('open');
      btn.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    })
  );

  // Language toggle — reloads to /{lang}/
  const langBtn = document.getElementById('lang-toggle')!;
  langBtn.addEventListener('click', () => {
    const current = langBtn.dataset.currentLang as string;
    const next    = current === 'en' ? 'es' : 'en';
    // Simple URL approach: /en/ or /es/
    const pathParts = window.location.pathname.split('/').filter(Boolean);
    if (pathParts[0] === 'en' || pathParts[0] === 'es') {
      pathParts[0] = next;
    } else {
      pathParts.unshift(next);
    }
    window.location.href = '/' + pathParts.join('/');
  });
</script>
